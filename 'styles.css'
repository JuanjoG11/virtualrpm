
/* =============================================
   ENHANCED PREMIUM PRODUCT CARDS 
   ============================================= */

.product-card-shop {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: linear-gradient(145deg, #121214 0%, #0a0a0b 100%);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
}

.product-card-shop:hover {
    transform: translateY(-12px) scale(1.02);
    border-color: rgba(255, 255, 255, 0.2);
    box-shadow: 0 20px 40px rgba(0,0,0,0.8), 0 0 20px rgba(212, 212, 216, 0.1);
}

.product-card-shop.out-of-stock {
    opacity: 0.85;
}

/* Image Enhancements */
.product-actions-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.4);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: all 0.4s ease;
    z-index: 5;
}

.product-card-shop:hover .product-actions-overlay {
    opacity: 1;
}

.quick-view-btn {
    background: #fff;
    color: #000;
    border: none;
    padding: 0.8rem 1.5rem;
    font-family: var(--font-primary);
    font-weight: 800;
    font-size: 0.75rem;
    letter-spacing: 1px;
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    transform: translateY(20px);
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
}

.product-card-shop:hover .quick-view-btn {
    transform: translateY(0);
}

.quick-view-btn svg { width: 16px; height: 16px; }

/* Info Area */
.product-status-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.8rem;
}

.product-sold-count {
    font-size: 0.65rem;
    font-weight: 700;
    color: #fbbf24;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    background: rgba(251, 191, 36, 0.1);
    padding: 2px 8px;
    border-radius: 20px;
}

.product-name {
    margin-bottom: 0.5rem;
    cursor: pointer;
    transition: color 0.3s ease;
}

.product-name:hover {
    color: var(--color-accent);
}

.product-compat {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent-dark);
    margin-bottom: 1.2rem;
    opacity: 0.8;
}

.product-price-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
}

.stock-indicator {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.stock-indicator .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
}

.stock-indicator.ok { color: #10b981; }
.stock-indicator.ok .dot { background: #10b981; box-shadow: 0 0 8px #10b981; }

.stock-indicator.low { color: #f59e0b; }
.stock-indicator.low .dot { background: #f59e0b; box-shadow: 0 0 8px #f59e0b; }

.stock-indicator.out { color: #ef4444; }
.stock-indicator.out .dot { background: #ef4444; }

/* Footer Actions */
.product-card-footer {
    display: flex;
    gap: 0.5rem;
    margin-top: auto;
}

.product-card-footer .add-to-cart-btn {
    flex: 1;
    justify-content: center;
    height: 48px;
    background: var(--color-white);
    letter-spacing: 1px;
}

.product-card-footer .add-to-cart-btn.disabled {
    background: #2d2d2d;
    color: #555;
    cursor: not-allowed;
}

.product-whatsapp-link {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(37, 211, 102, 0.1);
    color: #25D366;
    border: 1px solid rgba(37, 211, 102, 0.3);
    border-radius: 6px;
    transition: all 0.3s ease;
}

.product-whatsapp-link:hover {
    background: #25D366;
    color: #fff;
    transform: scale(1.05);
}

.product-whatsapp-link svg { width: 22px; height: 22px; }

/* Badge Overrides */
.product-badge.premium {
    background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
    color: #000;
}

.product-badge.out {
    background: #333;
    color: #fff;
    opacity: 0.9;
}

.product-badge.low {
    background: #ef4444;
    color: #fff;
    animation: blink 2s infinite;
}

@keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
}


/* =============================================
   INTERACTIVE SEARCH BAR STYLES
   ============================================= */

.catalog-search-container {
    max-width: 800px;
    margin: 0 auto 3rem;
    padding: 0 1rem;
    display: none; /* Hidden until a category or brand is selected */
    animation: fadeIn 0.5s ease-out;
}

.search-wrapper {
    position: relative;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 2px;
    overflow: hidden;
    transition: all 0.3s ease;
}

.search-wrapper:focus-within {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--color-accent);
    box-shadow: 0 0 25px rgba(212, 212, 216, 0.2);
    transform: scale(1.01);
}

.search-wrapper input {
    width: 100%;
    padding: 1.2rem 1.2rem 1.2rem 3.5rem;
    background: transparent;
    border: none;
    color: var(--color-white);
    font-family: var(--font-secondary);
    font-size: 1.1rem;
    outline: none;
}

.search-wrapper input::placeholder {
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.5px;
}

.search-icon {
    position: absolute;
    left: 1.2rem;
    top: 50%;
    transform: translateY(-50%);
    width: 22px;
    height: 22px;
    color: var(--color-accent);
    opacity: 0.5;
    transition: opacity 0.3s ease;
}

.search-wrapper:focus-within .search-icon {
    opacity: 1;
}

.search-glow {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 2px;
    background: var(--color-accent);
    transition: width 0.4s ease;
    box-shadow: 0 0 10px var(--color-accent);
}

.search-wrapper:focus-within .search-glow {
    width: 100%;
}

@media (max-width: 768px) {
    .search-wrapper input {
        font-size: 0.95rem;
        padding: 1rem 1rem 1rem 3rem;
    }
}


/* =============================================
   ENHANCED MODAL ELEMENTS
   ============================================= */

.modal-stock-status {
    margin: 2rem 0;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.05);
}

.stock-label-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.8rem;
    font-family: var(--font-primary);
    font-size: 0.8rem;
    letter-spacing: 1px;
}

.stock-status-text {
    color: var(--color-accent-dark);
    text-transform: uppercase;
}

.stock-percent {
    font-weight: 800;
    color: var(--color-accent);
}

.stock-progress-bar {
    width: 100%;
    height: 6px;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 0.8rem;
}

.stock-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #ef4444 0%, #f59e0b 50%, #10b981 100%);
    width: 100%;
    transition: width 1s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.stock-urgency-msg {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    text-align: center;
}

.modal-related {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.modal-related h4 {
    font-family: var(--font-primary);
    font-size: 0.85rem;
    letter-spacing: 2px;
    margin-bottom: 1.5rem;
    color: var(--color-accent-dark);
}

.related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
}

.related-item {
    cursor: pointer;
    transition: all 0.3s ease;
}

.related-item:hover {
    transform: translateY(-5px);
}

.related-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    margin-bottom: 0.5rem;
}

.related-name {
    font-size: 0.7rem;
    font-weight: 600;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.2;
}

